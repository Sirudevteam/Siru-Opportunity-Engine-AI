# Shared
ENVIRONMENT=local
DEFAULT_CURRENCY=INR

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./siru.db
REDIS_URL=redis://localhost:6379/0
FRONTEND_ORIGIN=http://localhost:3000
AUTO_CREATE_TABLES=true
# Set true only if you are running the backend manually without Redis.
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TIME_LIMIT_SECONDS=900

# Signed Siru dashboard requests
# Leave unset for unsigned local development.
SIRU_AUTH_SIGNATURE_SECRET=
SIRU_AUTH_SIGNATURE_TOLERANCE_SECONDS=300

# Integrations
GOOGLE_PLACES_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# S3-compatible object storage.
# Leave credentials blank to use local fallback behavior where supported.
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=siru-opportunity-engine
OBJECT_STORAGE_ACCESS_KEY=siru
OBJECT_STORAGE_SECRET_KEY=siru-password
OBJECT_STORAGE_PUBLIC_BASE_URL=http://localhost:9000/siru-opportunity-engine

# Vector database. Optional for local development.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=website_audits

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

