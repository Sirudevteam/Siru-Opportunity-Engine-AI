# Shared
ENVIRONMENT=local
DEFAULT_CURRENCY=INR

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://siru:siru@postgres:5432/siru_opportunity_engine
REDIS_URL=redis://redis:6379/0
FRONTEND_ORIGIN=http://localhost:3000

# Integrations
GOOGLE_PLACES_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# S3-compatible object storage
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=siru-opportunity-engine
OBJECT_STORAGE_ACCESS_KEY=siru
OBJECT_STORAGE_SECRET_KEY=siru-password
OBJECT_STORAGE_PUBLIC_BASE_URL=http://localhost:9000/siru-opportunity-engine

# Vector database
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=website_audits

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

